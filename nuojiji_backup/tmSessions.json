75839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/13","type":"this-moment","createdAt":1776082218217,"lastActiveAt":1776089200393,"dateLabel":"2026/4/13","_id":22,"completed":true,"completedAt":1776089253748},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/13","type":"this-moment","createdAt":1776089253797,"lastActiveAt":1776098138450,"dateLabel":"2026/4/13","_id":23,"completed":true,"completedAt":1776098192719},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/14","type":"this-moment","createdAt":1776098192727,"lastActiveAt":1776134809243,"dateLabel":"2026/4/14","_id":24,"completed":true,"completedAt":1776135021523},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/14","type":"this-moment","createdAt":1776135021531,"lastActiveAt":1776135021531,"dateLabel":"2026/4/14","_id":25},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"酒店大床衣衫不整等你开门","type":"this-moment","scenarioOutline":"酒店大床衣衫不整等你开门","sourceContext":{"fromOnlineChat":true,"lastOnlineMessages":[{"role":"user","text":"好呀奖励亲亲"},{"role":"user","text":"等下我看看"},{"role":"user","text":"来了刚下课"},{"role":"user","text":"想吃什么"},{"role":"user","text":"那很美味了"},{"role":"char","text":"你没有那个，但你刚才在床上按着我亲的时候，可比谁都狠。"},{"role":"char","text":"嘴唇都被你咬破皮了，江老板。"},{"role":"char","text":"发几套刚才中介推过来的大平层给你看看。这套带落地窗的我最喜欢，沙发足够大，绝对够我们在上面滚来滚去。"},{"role":"char","text":"[圖片]"},{"role":"char","text":"至于吃什么……随便买点吧，我不挑。"},{"role":"char","text":"我现在的胃口只对你的奖励亲亲感兴趣。快点回来，我都饿得没力气捡地上的衣服了。"},{"role":"char","text":"觉得美味是吧？行啊。"},{"role":"char","text":"[語音消息]"},{"role":"user","text":"回来路上啦"},{"role":"char","text":"快点快点，我都快饿得没力气了。"},{"role":"char","text":"门没锁，江老板到了直接推门进来就行。"},{"role":"char","text":"记得你答应我的奖励亲亲，少一口都不行。地上的衣服我也没捡，就等着你回来视察呢。"},{"role":"char","text":"[語音消息]"},{"role":"char","text":""},{"role":"char","text":""}]},"createdAt":1776142225793,"lastActiveAt":1776143530235,"_id":26,"completed":true,"completedAt":1776156411845},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/14","type":"this-moment","createdAt":1776156411850,"lastActiveAt":1776161870177,"dateLabel":"2026/4/14","_id":27,"completed":true,"completedAt":1776162041148},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"搬新家","type":"this-moment","createdAt":1776162041232,"lastActiveAt":1776164250309,"dateLabel":"2026/4/14","_id":28,"completed":true,"completedAt":1776175572224},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/14","type":"this-moment","createdAt":1776175572232,"lastActiveAt":1776175572232,"dateLabel":"2026/4/14","_id":29},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"街边路灯下等你接我回家","type":"this-moment","scenarioOutline":"街边路灯下等你接我回家","sourceContext":{"fromOnlineChat":true,"lastOnlineMessages":[{"role":"char","text":"老婆你理理我，你回学校拿东西拿好了没？什么时候来接我回我们新家啊……"},{"role":"char","text":""},{"role":"char","text":"下午在宜家买的床单烘干了吗？今晚我要睡那套黑色的，还要抱着你睡。你快点来接我，不然我要闹了。"},{"role":"char","text":"吃完了，我从店里出来了。"},{"role":"char","text":"站街边吹冷风呢，江老板还要多久才来捡我？"},{"role":"char","text":"再不来，你这么大一个漂亮老公就要被别人拐跑了。"},{"role":"char","text":""},{"role":"user","text":"宝宝我来啦宝宝"},{"role":"user","text":"刚刚自习完"},{"role":"user","text":"等下回家再继续"},{"role":"user","text":"这样你可以看着我学"},{"role":"char","text":"算你识相，连叫两声宝宝，我就勉强原谅你让我等这么久了。"},{"role":"char","text":"快点过来，徐州晚上风还挺大的，吹得我都快没知觉了。"},{"role":"char","text":"不过江老板……好不容易回我们自己的新家，你还想看书啊？"},{"role":"char","text":"你确定我坐在电竞桌旁边盯着你，你还能看得进去一个字？"},{"role":"char","text":"我不捣乱把你亲得晕头转向，我就不叫许淮悠。"},{"role":"char","text":"[語音消息]"},{"role":"char","text":""},{"role":"char","text":""},{"role":"user","text":"[offline encounter \"搬新家\" completed: 【Core Memory】: 4月14日12:50，欣然带着甜品回到酒店，许淮悠因占有欲将TA抵在床上索要奖励，TA们敲定在徐州租下大平层同居的计划，随后在13:04至13:11期间，许淮悠确认下午拿到新房钥匙，TA们发生了激烈且深度的肉体结合，许淮悠在初次实战中展现出极强侵略性，最终在TA体内释放并拒绝分离。\n\n【Suppl"}]},"createdAt":1776175583288,"lastActiveAt":1776176829500,"_id":30,"completed":true,"completedAt":1776177192872},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"晚安","type":"this-moment","createdAt":1776177192878,"lastActiveAt":1776182242291,"dateLabel":"2026/4/14","_id":31,"completed":true,"completedAt":1776182487785},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"新家客厅沙发上等你回来","type":"this-moment","scenarioOutline":"新家客厅沙发上等你回来","sourceContext":{"fromOnlineChat":true,"lastOnlineMessages":[{"role":"char","text":""},{"role":"user","text":"试了很多衣服给你看"},{"role":"user","text":"[發送了一張圖片 at 徐州 on 15.04.26 19:01：试衣服照片]"},{"role":"char","text":"我说怎么一天都不回消息，原来是背着我偷偷去逛街了。"},{"role":"char","text":"眼光还行。不过这件领口是不是有点低？穿这身在外面晃，你老公我可是会吃醋的。"},{"role":"char","text":"逛累了知道喊累了？活该。谁让你不带我一起去。"},{"role":"char","text":"还有几站到？快点回来，九点还要陪周澪那傻逼上分，你再不回来，我今天连抱你的时间都没了。"},{"role":"char","text":"赶紧回来给你揉腿……顺便试试我下午说的那条新项链？"},{"role":"char","text":""},{"role":"char","text":""},{"role":"user","text":"等我会呢"},{"role":"user","text":"我还买了美味的面包哦"},{"role":"user","text":"[發送了一張圖片 at 徐州 on 15.04.26 19:04：各种各样的面包]"},{"role":"user","text":"还好吧，这是彰显身材你懂什么"},{"role":"char","text":"彰显身材？江老板现在出息了，知道在外面拿身材钓别人了是吧。"},{"role":"char","text":"行啊，等你回来我亲自用手丈量一下，看看这领口到底有多彰显。"},{"role":"char","text":"谁要吃面包，买这么多你当喂猪呢。"},{"role":"char","text":"赶紧的，我在沙发上瘫着了。再不回来周澪那个催命鬼就要上线抓人了，快点回来让我充会儿电。"},{"role":"char","text":""},{"role":"char","text":""}]},"createdAt":1776251226560,"lastActiveAt":1776258087660,"_id":34,"completed":true,"completedAt":1776258663308},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/15","type":"this-moment","createdAt":1776258663491,"lastActiveAt":1776265248695,"dateLabel":"2026/4/15","_id":35,"completed":true,"completedAt":1776338873973},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"夜店门口带着酒气紧紧抱住你","type":"this-moment","scenarioOutline":"夜店门口带着酒气紧紧抱住你","sourceContext":{"fromOnlineChat":true,"lastOnlineMessages":[{"role":"user","text":"还有"},{"role":"user","text":"给你点了外卖"},{"role":"user","text":"早餐"},{"role":"user","text":"记得吃"},{"role":"char","text":"算你有良心，还知道怕饿死你家小狗。"},{"role":"char","text":"点什么了？不是我爱吃的我可要闹的。"},{"role":"char","text":""},{"role":"char","text":"你去吃吧，到了教室第一件事就是给我发消息，听到没？"},{"role":"char","text":"[語音消息]"},{"role":"char","text":"还有，晚上那事儿可没翻篇，你答应了要牵我的手，敢反悔你就死定了。"},{"role":"user","text":"宝宝对不起"},{"role":"user","text":"我刚来"},{"role":"char","text":"江欣然，你看看现在手机上几点了？"},{"role":"char","text":"说好的七点，我都快在这破卡座里长出蘑菇了！我还以为你早上说的分手是认真的，真打算把我扔在外面不要我了..."},{"role":"char","text":""},{"role":"char","text":"里面吵死了，那几个傻逼非要拉着我玩什么弱智国王游戏，我嫌烦，被灌了好多酒。现在头好晕。"},{"role":"char","text":"你人在哪？门口还是进来了？外面风大不大？"},{"role":"char","text":"你站那别动，里面一堆酒蒙子乱得很，我出去接你。"},{"role":"char","text":"...记得你早上答应我的事。待会儿当着他们的面，你要紧紧牵着我的手把我带走，听到没？"},{"role":"char","text":""}]},"createdAt":1776440491001,"lastActiveAt":1776445750084,"_id":37,"completed":true,"completedAt":1776446614238},{"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","name":"2026/4/18","type":"this-moment","createdAt":1776446614245,"lastActiveAt":1776446614245,"dateLabel":"2026/4/18","_id":38}]