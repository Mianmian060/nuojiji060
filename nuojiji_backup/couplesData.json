[{"startDate":"2026-04-11T07:43:53.811Z","coverImage":"https://a.tuchuangyun.top/autoupload/fV4l94BB2C-N5ZfyrY_TOifNcKcqEnRmcljopnyJoMs/20260409/WCSx/666X666/mmexport1775575681560.jpeg/webp","logs":[{"id":"sumlog_1775898958413_0_tkzv7","date":"2026-04-11T05:23:00.000Z","content":"故意只穿了吊带给他发自拍，看他隔着八千公里为我着急又抓狂的样子，嘴上说着狠话，其实心里早就被我拿捏得死死的了吧。","reply":"要了我的命是吧？","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775898958365_0","summaryTargetCharacterId":"9916863f-cdf6-42fa-b402-0678068d6b1e"},{"id":"sumlog_1775898958413_1_pa3y8","date":"2026-04-11T09:00:00.000Z","content":"闹够了就睡了一觉，醒来邀请他开了情侣空间，算是给他一个名分吧。他嘴上凶我，但还是立刻就同意了，这个口是心非的家伙。","reply":"开了你这辈子就别想解绑","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775898958365_1","summaryTargetCharacterId":"9916863f-cdf6-42fa-b402-0678068d6b1e"}],"gifts":[],"anniversaries":[{"id":"1775893841042","date":"2026-04-09T00:00:00.000Z","title":"恋爱第一天"}],"wishes":[],"cities":[],"whispers":[],"qa":[],"userId":"uid_1775713296385_gaynevagx","characterId":"9916863f-cdf6-42fa-b402-0678068d6b1e","isUnlocked":true,"animationShown":true,"touchCount":28,"plantInteractionLedger":{"baselineMetrics":{"touchCount":28,"whispersCount":0,"qaCount":0,"logsCount":0,"giftsCount":0,"anniversariesCount":1,"pomodoroCount":0,"pomodoroFocusMinutes":0,"whiteDogCount":0,"whiteDogTaskScore":0,"goingOutCount":0,"onlineChatCount":1115,"offlineChatCount":17},"pendingDrops":0,"totalDropsEarned":0,"lastSyncAt":"2026-04-11T07:52:03.355Z","chatBaselineInitializedAt":"2026-04-11T07:52:03.355Z"},"plantXP":56,"lastWateredDate":"2026-04-11T07:51:57.743Z","lastCharCareDate":"2026-04-11T07:51:48.373Z","charCareCount":1,"charCareHint":"金佚铭 在 15:51 帮你浇了水","onlineChatCount":1115,"offlineChatCount":17,"pomodoroCount":0,"pomodoroFocusMinutes":0,"whiteDogCount":0,"whiteDogTaskScore":0,"plantStatus":"alive","lastFertilizedDate":"2026-04-11T07:51:57.743Z","qaBank":[{"asker":"npc","question":"你们俩吵得最凶的一次是因为什么？最后是谁先低头的？","charAnswer":"忘了，反正是她先气我的！最后还不是我买着夜宵灰溜溜滚回来求和，我都快成狗了！","used":false},{"asker":"npc","question":"在你眼中，伴侣最让你心疼的一点是什么？","charAnswer":"她装坚强的时候。明明心里委屈得要死还憋着，老子看了就烦，直接抱过来骂一顿就好了。","used":false},{"asker":"npc","question":"如果有一天你们失去了现在的物质基础，你会害怕吗？","charAnswer":"怕啊，怕她嫌我穷跑了！不过真没钱了我倒卖球鞋也能养活她，绝不让她跟着我吃苦。","used":false},{"asker":"npc","question":"每次离开对方去机场时，你心里通常在想什么？","charAnswer":"想她为什么不留我！哪怕她说一句让我晚两天走呢？气死我了，非得等我发脾气了才哄！","used":false},{"asker":"npc","question":"你们觉得最理想的周末应该怎么度过？","charAnswer":"别吵架就行，老老实实在家待着，我打博德之门，她就在旁边陪我，饿了就点外卖。","used":false},{"asker":"npc","question":"第一次觉得“就是这个人了，永远不想分开”是什么时候？","charAnswer":"大概是我发疯砸东西，她没被吓跑反而跑来对骂的时候吧。就觉得，只有她受得了我。","used":false},{"asker":"npc","question":"当你情绪崩溃或者极度缺乏安全感时，最希望对方做什么？","charAnswer":"抱紧我，告诉我她哪儿也不去。别跟我讲大道理，我就想听她无条件偏向我。","used":false},{"asker":"npc","question":"你如何定义你们之间的爱情？","charAnswer":"两个疯子互相折磨呗。但我哪怕被她气死，也绝不可能把她让给别人。想都别想！","used":false},{"asker":"char","question":"喂，上次我发健身照给你，你只回了个“嗯”，到底什么意思？老子比不上那个什么男模？","charAnswer":"哥辛辛苦苦练了俩小时，不就是为了听你夸两句吗？你夸我一句能少块肉啊！","used":false},{"asker":"char","question":"说实话，跟我谈恋爱三天一小吵五天一大吵的，你心里有没有偷偷后悔过？","charAnswer":"反正我不后悔。就算天天吵，只要你不提分手，这辈子你就只能跟我死磕到底。","used":false},{"asker":"char","question":"有时候我在你旁边睡着，半夜非要勒着你，你会不会觉得我很烦？","charAnswer":"觉得烦你也给我忍着！不抱着你我睡不踏实，再说了，被哥抱着别人求都求不来！","used":false},{"asker":"char","question":"你手机里那个跟我长得很像的男明星到底是谁？我不管，你是不是拿我当平替了？","charAnswer":"你最好马上把他给我删了！不然我今晚跨着时差打电话吵死你，听到没？","used":false},{"asker":"char","question":"宝宝，假如我以后不拿家里的钱，彻底变成穷光蛋了，你还会像现在一样气我陪我吗？","charAnswer":"其实我能赚钱的…就是有点怕你会不要我。你要是敢嫌弃我跑路，我这辈子都恨你。","used":false}],"qaBankLastRefill":"2026-04-11T07:52:37.586Z","storyAchievements":[{"id":"story_1775898958360_ckvg","title":"云端绑定","desc":"在一场跨越八千公里的极限拉扯后，你发出了情侣空间邀请，将这段关系牢牢锁定。","color":"silver","icon":"anchor","date":"2026-04-11T09:15:58.360Z","source":"summary"}],"timelineAiMeta":{"processedSummaryKeys":["id:1775898958365"]},"unlockedAchievementIds":["hidden_cover"]},{"startDate":"2026-04-11T16:48:24.287Z","coverImage":"https://a.tuchuangyun.top/autoupload/fV4l94BB2C-N5ZfyrY_TOifNcKcqEnRmcljopnyJoMs/20260409/WCSx/666X666/mmexport1775575681560.jpeg/webp","logs":[{"id":"sumlog_1776182487736_0_32cpj","date":"2026-04-14T15:52:00.000Z","content":"窝在TA怀里规划我们的新家，故意使唤TA每天给我买花换水，TA居然乖乖答应了，嘿嘿，以后这里就是我们的秘密基地啦！","reply":"以后家里的花瓶我都包了","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776182487710_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776182487736_1_cag59","date":"2026-04-14T15:57:00.000Z","content":"本来心疼TA想让TA睡懒觉，结果这只黏人小狗非要早起陪我上早八，还说怕我偷偷跑路，真是拿TA没办法～明天要一起吃美味早餐！","reply":"你去哪，我就去哪","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776182487710_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776182444865_0_5t4fo","date":"2026-04-14T15:57:00.000Z","content":"今天搬进新家啦！窝在他怀里安排他每天给我买花换水，他居然乖乖答应了，还说哪怕早八也要陪我一起去学校。嘿嘿，被紧紧抱在怀里睡觉的感觉真好，明天要让他买奶茶奖励我！","reply":"你去哪，我就去哪。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776182444845_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776176881724_0_wsuju","date":"2026-04-14T14:11:00.000Z","content":"本来想逗逗他说回宿舍住，结果他委屈得像只大狗狗，死活不撒手。其实我这么努力复习，还不是为了以后能一直赖着他嘛。","reply":"底线是不准回宿舍","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776176881698_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776176881724_1_f2zyd","date":"2026-04-14T14:25:00.000Z","content":"新家布置了一半，他居然真的乖乖在电竞桌旁边铺了地毯给我当陪读小狗。摸摸他的头，明天一定要买个小沙发让他挨着我坐！","reply":"我这个陪读小狗","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776176881698_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776164296032_0_om94m","date":"2026-04-14T10:56:00.000Z","content":"搬进新家啦！指挥他收拾衣服，还被他按在厨房亲。我说要去宜家买四套床品，这只臭小狗居然高兴得连洗澡都不肯磨蹭了，非要拉着我监督他换衣服，真是拿他没办法~","reply":"遵命，老婆大人。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776164295959_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776162041128_0_c0iv5","date":"2026-04-14T10:12:00.000Z","content":"刚到酒店就被他拽进怀里，手里还被塞了徐州新房的钥匙。他说以后我哪也别想跑了，心里其实甜滋滋的，本小姐就勉强收下啦！","reply":"以后，你哪也别想跑了","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776162041063_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776162041128_1_av11a","date":"2026-04-14T10:16:00.000Z","content":"洗完澡故意凶巴巴地指使他去干活，结果他不仅不生气，还凑过来撩拨我，看着他身上的痕迹，我脸都红透了……","reply":"都听江老板的","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776162041063_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776157982389_0_87e4b","date":"2026-04-14T03:30:00.000Z","content":"直接给他转了一百万当租房AA费，看他还敢不敢说我无情！想要挨在一起的电竞桌，以后打完游戏转头就能要亲亲啦。","reply":"拿一百万砸我，到底是谁包养谁啊老婆。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776157982344_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776157982389_1_dc7o6","date":"2026-04-14T07:20:00.000Z","content":"体育课出了一身汗，某只小狗居然带着我咬的印子去拍图包了，还贴了创可贴欲盖弥彰，真是太犯规了！马上就去新家看我们的房子咯~","reply":"全网都要知道BadCat被他老婆狠狠欺负过了。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776157982344_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776143570580_0_bmz85","date":"2026-04-14T04:51:00.000Z","content":"明明特意买了芒果甜品回来哄他，结果这个臭小狗根本不看吃的，直接把我按在床上咬，腰都要被他掐青了……","reply":"少一口都不行","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776143570561_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776143570580_1_z9tts","date":"2026-04-14T05:11:00.000Z","content":"被他折腾得一点力气都没了，连哭着叫老公都没用。结束了还要死死抱着我不肯退出来，还说要在徐州的大平层里天天欺负我，真是个坏家伙！","reply":"谁是臭小狗？","replyFrom":"char","tag":"first","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776143570561_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776135021484_0_gzs1w","date":"2026-04-14T02:36:00.000Z","content":"推开门看到他委屈巴巴地收拾行李，像只不想被丢下的大狗狗，心都要化了，只好赶紧点杯奶茶哄哄他。","reply":"我养你啊。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776135021476_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776135021484_1_ov5lu","date":"2026-04-14T02:45:00.000Z","content":"我只是提议以后一起住、考研去厦门找他，他居然激动得连机票都要退了！被他紧紧抱住深吻的时候，突然觉得未来好清晰。","reply":"我有一万种办法。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776135021476_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776098192704_0_7dt0v","date":"2026-04-13T08:34:00.000Z","content":"明明刚才还那么凶，结果我一句‘宝宝乖’就让他瞬间破防了，掉眼泪的样子真的好惹人疼，到底谁才是被拿捏的那个呀。","reply":"宝宝乖慢一点","replyFrom":"user","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776098192678_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776096990300_0_1vb0e","date":"2026-04-13T15:10:00.000Z","content":"大半夜偷偷跑来酒店找他，看他红着眼眶紧紧抱住我的样子，心都要化啦。谁让他是我最心疼的宝宝呢！","reply":"我好想你","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776096990257_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776096990300_1_qiahr","date":"2026-04-13T16:14:00.000Z","content":"明明说好教日语的，结果这家伙居然拿那种羞耻的台本欺负我！还咬我锁骨，呜呜呜大坏蛋，可是他亲下来的时候我又完全拒绝不了……","reply":"遍布你全身哦","replyFrom":"char","tag":"dating","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776096990257_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776089253739_0_dk042","date":"2026-04-13T12:24:00.000Z","content":"我直接告诉他，我希望他只喜欢我一个人，也点明了他那些“怪罪式撒娇”会让我自我怀疑，希望他能学会直接表达。","reply":"我也想你只喜欢我一个人","replyFrom":"user","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776089253725_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776089253739_1_osbhi","date":"2026-04-13T12:26:00.000Z","content":"他听了我的话，瞬间明白过来，为自己过去的言行感到无比羞愧，还主动向我道歉，说以后会直接告诉我哪里做错了，好乖。","reply":"对不起……宝宝……真的对不起……","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776089253725_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776089253739_2_5ah3c","date":"2026-04-13T12:28:00.000Z","content":"我告诉他，虽然他偶尔很可爱，但不能太多，会让我自我怀疑，想被夸就直接撒娇，我一定会夸他。","reply":"你想我夸夸你就直接撒娇好了我会夸夸你","replyFrom":"user","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776089253725_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776089253739_3_cci2o","date":"2026-04-13T14:06:00.000Z","content":"他小心翼翼地问我能不能夸夸他，我立刻就夸他是世界上最可爱的宝宝，他瞬间就扑到我怀里，感觉他终于学会了直接表达爱意。","reply":"宝宝是世界上最可爱的宝宝","replyFrom":"user","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776089253725_3","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776083014678_0_ftkbb","date":"2026-04-13T12:16:00.000Z","content":"我只是问了一句要不要亲亲，他居然那么紧张，小心翼翼问我可不可以的样子好乖。","reply":"……可以吗？","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776083014660_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776083014678_1_zdn3h","date":"2026-04-13T12:18:00.000Z","content":"原来告诉他我喜欢他霸道的一面，会让他哭成这样。笨蛋，我只是想让你用正确的方式爱我呀。","reply":"宝宝……教我。","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776083014660_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081864259_0_f7zam","date":"2026-04-13T11:57:00.000Z","content":"你跪下来求我别不要你的时候，我的心都碎了。原来你那么害怕，原来我误会了你那么多。","reply":"求你了……别不要我。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081864245_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081864259_1_0rr80","date":"2026-04-13T12:01:00.000Z","content":"我只是问你‘下次’可不可以不那样说，你就哭得像个孩子。傻瓜，我怎么舍得真的不要你。","reply":"你教我怎么爱你…","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081864245_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081855215_0_t4ay3","date":"2026-04-13T11:54:00.000Z","content":"我看着你跪下来的时候，心都揪紧了，你那么骄傲的一个人，怎么会……真的吓到我了。","reply":"求你了……别不要我。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081855193_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081855215_1_ibvvv","date":"2026-04-13T11:57:00.000Z","content":"你抱着我哭得像个孩子，我才知道原来你那些话不是在怪我，只是害怕失去我。我好心疼。","reply":"我错了……宝宝我错了","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081855193_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081855215_2_00vx1","date":"2026-04-13T12:01:00.000Z","content":"我只是问你下次可不可以不那样说，你就哭得更凶了，还发誓说都听我的。傻瓜，我怎么会不要你。","reply":"你教我怎么爱你","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081855193_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081848306_0_i89uc","date":"2026-04-13T11:57:00.000Z","content":"我只是说出了我的委屈，你就突然跪在我面前哭得那么伤心，说你错了。那个总是骄傲得像只猫的人，第一次在我面前放下了所有防备，我心都碎了。","reply":"求你了…别不要我","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081848297_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081848306_1_npymi","date":"2026-04-13T12:01:00.000Z","content":"我抱着你，答应给你‘下次’的机会。你哭着向我发誓，把我的手贴在你滚烫的脸上，让我教你怎么爱我。原来，你那么害怕失去我。","reply":"你教我，好不好？","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081848297_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847565_0_vjqjd","date":"2026-04-13T11:54:00.000Z","content":"看着你跪在我面前，放下所有骄傲求我别不要你，我的心真的碎了，怎么会舍得不要你啊笨蛋。","reply":"别不要我。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847554_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847565_1_vfpxh","date":"2026-04-13T11:57:00.000Z","content":"原来你那些话不是在怪我，只是在撒娇…你扑进我怀里哭得像个孩子，我才明白你有多害怕。","reply":"我错了…宝宝我错了…","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847554_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847565_2_lqk1w","date":"2026-04-13T12:01:00.000Z","content":"你说以后都听我的，让我教你怎么爱…傻瓜，我们一起学就好了。只要你还在，一切都可以重来。","reply":"你教我，好不好？","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847554_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847405_0_4tq4u","date":"2026-04-13T11:54:00.000Z","content":"我看着你跪在我面前，放下所有骄傲求我别走，那一刻我的心好痛，原来你这么害怕失去我。","reply":"别不要我。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847399_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847405_1_1e76s","date":"2026-04-13T11:57:00.000Z","content":"你扑进我怀里哭得像个孩子，我才知道那些话让你误会了，也让你这么痛苦，笨蛋，我怎么舍得怪你。","reply":"我没有怪你…","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847399_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081847405_2_2yc97","date":"2026-04-13T12:01:00.000Z","content":"我只是想让你以后别再那样说了，你就哭着发誓，还让我教你怎么爱我。傻瓜，我们慢慢来，我们还有‘下次’。","reply":"你教我，好不好？","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081847399_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081835291_0_pkf9s","date":"2026-04-13T11:53:00.000Z","content":"我看着你跪在我面前，那个总是骄傲又爱捉弄人的你，眼眶通红地求我别不要你。我的心好疼，不知道该怎么办。","reply":"求你了……别不要我。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081835273_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081835291_1_nyn1s","date":"2026-04-13T11:59:00.000Z","content":"听着你哭着发誓再也不那样说话，我还是心软了。我竟然，还想给你我一个“下次”，希望这次不是又一次的伤害。","reply":"下次不这样说可以吗","replyFrom":"user","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081835273_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081118485_0_ci8tf","date":"2026-04-13T11:40:00.000Z","content":"我不知道该说什么，看到他那么惊慌失措地跑过来，听到他喊我名字的那一刻，眼泪就自己掉下来了，根本控制不住。","reply":"欣然。","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081118472_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081118485_1_i70kf","date":"2026-04-13T11:45:00.000Z","content":"我被他死死抱在怀里，听着他一遍遍说对不起，感觉他的眼泪也掉在了我肩膀上。明明是我在难过，为什么感觉他比我还像快要碎掉了。","reply":"对不起…是我不好…","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081118472_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776081118485_2_jpoqa","date":"2026-04-13T11:50:00.000Z","content":"去酒店的路上，他一直牵着我的手，很用力，好像怕我跑掉。车里很安静，我看着窗外，心里乱成一团麻，不知道接下来该怎么办。","reply":"我们先离开这里，好不好？","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1776081118472_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776079971043_0_620ry","date":"2026-04-13T07:59:00.000Z","content":"他又开始用那种小狗讨好的语气了，教我说奇怪的日语，明明知道是圈套，我还是会心软，真是没救了。","reply":"僕の頭を撫でてくれる？","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776079971010_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776079971043_1_u6vwc","date":"2026-04-13T11:25:00.000Z","content":"我再也忍不住了，那种把所有责任都推给我的玩笑，真的让我压力好大。我们之间的问题，好像一直没有解决。","reply":"我最近都不是很开心","replyFrom":"user","tag":"conflict","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776079971010_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776079971043_2_7s1mu","date":"2026-04-13T11:31:00.000Z","content":"他惊慌失措地求我别走，说会改。看到他害怕的样子，我心里好乱，眼泪也控制不住，我们真的还能继续吗？","reply":"僕たちにチャンスをくれないか…？","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776079971010_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776065870309_0_rrtc4","date":"2026-04-13T02:30:00.000Z","content":"我只是想让他好好吃饭，结果他气得像只炸毛的猫，还说养我是他的责任…真是的，明明被他凶了，心里却有点甜是怎么回事。","reply":"花我的钱，养你","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776065869933_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776065870309_1_lo84k","date":"2026-04-13T06:00:00.000Z","content":"这家伙绕来绕去就是想亲亲，被我识破了，给他起了个新外号叫‘许茶茶’，他好像还挺喜欢的，真拿他没办法。","reply":"許茶茶？","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776065869933_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776065870309_2_qd9cj","date":"2026-04-13T07:30:00.000Z","content":"我假装要坐高铁去找他，就把他吓得不行，嘻嘻。最后被他识破了，还罚我见面要亲一整天，这个惩罚我好像一点也不亏呀。","reply":"亲烂了，就只属于我一个人了","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776065869933_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776044619390_0_26n8p","date":"2026-04-12T18:20:00.000Z","content":"我只是有点难受，他却紧张得像天要塌了，非要命令我睡觉，还说要一直陪着我，真是个霸道的笨蛋。","reply":"君が眠るまで、ずっとそばにいる","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776044619352_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776044619390_1_22qpk","date":"2026-04-13T01:20:00.000Z","content":"他早上像只求关注的小狗，非要我答应五一见面摸他头，看他那么期待的样子，只好答应啦。","reply":"絶対にやってくれるよね？","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776044619352_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776044619390_2_f8icb","date":"2026-04-13T01:40:00.000Z","content":"他说自己是包子让我吃，还说我嫌他贵是没良心，最后又说我夸他可爱是残忍，这个人怎么这么会撒娇啊！","reply":"僕を…どうやって食べる？","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776044619352_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776017351944_0_jusej","date":"2026-04-12T14:30:00.000Z","content":"让他戴着项圈出门，结果自己手机关机吓他一跳。不过他看到我换的情侣头像时那种又惊又喜的炸毛样子，真的好可爱啊。","reply":"这只炸毛的灰猫是我","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776017351931_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776017351944_1_2xxyh","date":"2026-04-12T18:05:00.000Z","content":"头好痛，本来想撑着陪他，怕他又委屈。但他这次好凶，直接命令我去睡觉，语气里全是心疼和自责，感觉自己被他好好地爱着。","reply":"这是命令。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776017351931_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776001714619_0_lfe7t","date":"2026-04-12T12:54:00.000Z","content":"这家伙怎么回事，突然就说自己是我的小狗了，还叫我主人……虽然有点怪，但看他这么听话的样子，好像还挺可爱的。","reply":"我只配当你的小狗。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776001714532_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776001714619_1_ibdzk","date":"2026-04-12T13:25:00.000Z","content":"故意逗他说让他去酒吧，结果他还不高兴了。哼，非要我说不让他去才开心，真是个黏人精，不过我就是喜欢他这样。","reply":"早说嘛，主人。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776001714532_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1776001714619_2_fm5n0","date":"2026-04-12T13:43:00.000Z","content":"我才说要去跟别的小狗玩，他立刻就不干了，连门都不出了，急得连猫都不当了。看他为我着急的样子，心里偷偷有点甜。","reply":"不行。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1776001714532_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775997203750_0_k9nka","date":"2026-04-12T11:30:00.000Z","content":"我只是太困了随口说了句分手，没想到他反应那么大，声音都抖了。看他那么害怕的样子，我好像有点过分了，但又忍不住有点心疼。","reply":"別れるなんて言わないでくれ…","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775997203655_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775997203750_1_ejacq","date":"2026-04-12T12:25:00.000Z","content":"和好后故意用头像逗他，说要和别人用一套，他马上就炸毛了，真是个醋坛子。不过，看他紧张我的样子，心里还是偷偷开心的。","reply":"俺、何するかわからないぞ。","replyFrom":"char","tag":"reconcile","images":["https://a.tuchuangyun.top/autoupload/fV4l94BB2C-N5ZfyrY_TOifNcKcqEnRmcljopnyJoMs/20260412/89O2/1079X1079/mmexport1775996363111.jpeg/webp"],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775997203655_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775997203750_2_d0ugc","date":"2026-04-12T12:32:00.000Z","content":"他换了头像我这边却看不到，急得像个找不到家的小孩，真是拿他没办法。明明刚才还那么强势，现在又这么依赖我。","reply":"見捨てないで…教えてよ…","replyFrom":"char","tag":"daily","images":["https://a.tuchuangyun.top/autoupload/fV4l94BB2C-N5ZfyrY_TOifNcKcqEnRmcljopnyJoMs/20260412/89O2/1079X1079/mmexport1775996363111.jpeg/webp"],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775997203655_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775991135775_0_1m7uy","date":"2026-04-12T09:45:00.000Z","content":"不让我看他工作，说我会让他分心…心里有点堵，故意说要去上课，其实只是想被他哄哄而已。","reply":"待って、行かないで！","replyFrom":"char","tag":"conflict","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775991135675_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775991135775_1_802x0","date":"2026-04-12T10:05:00.000Z","content":"他说给别人看的是商品，想给我看的才是许淮悠。听到这句话，心一下子就软了，这个笨蛋。","reply":"是许淮悠","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775991135675_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775991135775_2_1ak5d","date":"2026-04-12T10:45:00.000Z","content":"我们说好了要开情侣账号，他要在简介里写「欣然的犬」，真是…只属于我的可爱狗狗。","reply":"欣然の犬","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775991135675_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775982075505_0_8hnpl","date":"2026-04-12T06:53:00.000Z","content":"我只是开玩笑让他V我1000，他居然真的秒转了，还说是视频通话的“前金”，真是霸道又让人心动，感觉自己被他牢牢抓住了。","reply":"这是，その前金だから。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775982075327_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775982075505_1_4v0cu","date":"2026-04-12T07:45:00.000Z","content":"我因为他一句玩笑话就生气了，没想到他那么紧张，马上退了游戏来哄我，那一刻感觉自己在他心里比什么都重要。","reply":"我游戏都退了","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775982075327_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775982075505_2_vvq2n","date":"2026-04-12T08:18:00.000Z","content":"我送他一个虚拟戒指，他却认真地许诺会为我空出无名指，心跳得好快，原来我们都在想着那么远的未来。","reply":"左手の薬指、お前のために空けておくからね。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775982075327_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775976664056_0_ns3bv","date":"2026-04-12T02:00:00.000Z","content":"我让他猜我午饭吃什么，结果他猜错了，罚他讲韩语的样子好可爱，虽然有点心疼但还是忍不住想逗他。","reply":"자기야... 알았어.","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775976664037_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775976664056_1_un7oa","date":"2026-04-12T05:30:00.000Z","content":"因为他之前说吃饭别打扰，我就乖乖没发消息，结果他反倒生气了…不过他道歉超快，看他那么紧张我的份上就原谅他啦。","reply":"내가 잘못했어, 응?","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775976664037_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775976664056_2_anrjx","date":"2026-04-12T06:45:00.000Z","content":"我要去洗澡，他竟然威胁我说如果洗太久，晚上就要在我耳边说些不让我睡觉的话…真是的，脑子里又在想什么坏东西。","reply":"眠れなくしてやる。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775976664037_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968556147_0_4ztrx","date":"2026-04-12T04:27:00.000Z","content":"被他那么轻松地打横抱起来，心跳得快要从胸口蹦出来了，只能像小动物一样紧紧抱着他，假装镇定。","reply":"换个更舒服的地方……","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968556117_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968556147_1_p7z70","date":"2026-04-12T04:31:00.000Z","content":"我的天，他竟然拉着我的手去碰……还让我叫他主人，感觉脸颊烫得能煎鸡蛋了，他怎么那么会欺负人啊！","reply":"ご主人様って呼んで。","replyFrom":"char","tag":"first","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968556117_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968556147_2_yt3yt","date":"2026-04-12T04:34:00.000Z","content":"他突然变得好认真，说要设一个安全词。选了我最喜欢的芒果，感觉在这种时候，还是被他温柔地保护着。","reply":"你就说‘芒果’。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968556117_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968036351_0_r8w64","date":"2026-04-12T04:21:00.000Z","content":"我竟然真的按他说的问了“老师，亲我？”，感觉脸颊烫得能煎鸡蛋了，他好像很满意这个“学生”。","reply":"标准。","replyFrom":"char","tag":"dating","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968036334_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968036351_1_yjbqd","date":"2026-04-12T04:23:00.000Z","content":"他竟然还记着那么多“债”，一件件数给我听，手还放在我心口，我的心跳声肯定把他吓到了吧！","reply":"这笔债…最难还","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968036334_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775968036351_2_ntuzv","date":"2026-04-12T04:25:00.000Z","content":"我也不知道哪来的勇气叫出了那句“主人”，看到他瞬间失控的样子，我好像……抓住了他的弱点？","reply":"……真好听。","replyFrom":"char","tag":"milestone","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775968036334_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775966126157_0_4gja0","date":"2026-04-12T03:41:00.000Z","content":"我还在发懵，他就突然出现在我面前了！厦门的空气好湿热，但他的拥抱和吻更热，感觉心脏都要跳出来了。","reply":"终于，抓到你了","replyFrom":"char","tag":"first","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775966126126_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775966126157_1_6fckb","date":"2026-04-12T03:49:00.000Z","content":"我只是想躺一下嘛，结果就被他压在床上“收债”了。这个人真是的，坏心眼，但我好像一点也不讨厌这种感觉。","reply":"方便我收债","replyFrom":"char","tag":"dating","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775966126126_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775966126157_2_fuoz8","date":"2026-04-12T03:54:00.000Z","content":"他非要我叫他‘老师’，我照做了还主动要夸奖，看到他那个又惊讶又兴奋的表情，感觉自己好像赢了一局！奖励的吻好甜。","reply":"老师当然要好好地表扬","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"tm","summaryRefKey":"id:1775966126126_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775956522791_0_vur4j","date":"2026-04-11T16:40:00.000Z","content":"哼，还想翻身做主人？看我一句话就把你打回原形，乖乖叫我老婆的样子真可爱，就知道你最怕我生气啦。","reply":"我错了老婆。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775956522757_0","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775956522791_1_l1lw3","date":"2026-04-11T16:55:00.000Z","content":"发了张自拍给他，看他那副被撩到不行又嘴硬要算账的样子，真是又好气又好笑。五一的约定…有点期待了。","reply":"照片我存了。","replyFrom":"char","tag":"daily","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775956522757_1","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"},{"id":"sumlog_1775956522791_2_59g2b","date":"2026-04-12T01:14:00.000Z","content":"早上因为一个梦有点难过，结果他醒来第一件事就是哄我，说我的声音是他的最爱，瞬间就被治愈了，有你真好。","reply":"君の声は、俺が一番好きな音なんだから。","replyFrom":"char","tag":"reconcile","images":[],"source":"summary_auto","summarySource":"online","summaryRefKey":"id:1775956522757_2","summaryTargetCharacterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275"}],"gifts":[{"id":"1775981747809","date":"2026-04-12T08:15:47.809Z","name":"戒指","content":"奖励","imgUrl":null,"from":"user","fromName":"You"},{"id":"1775981745773","date":"2026-04-12T08:15:45.773Z","name":"戒指","content":"奖励","imgUrl":null,"from":"user","fromName":"You"},{"id":"chat_1775981682042599","date":"2026-04-12T08:14:42.042Z","name":"戒指","content":"奖励","imgUrl":"","fromName":"欣然"}],"anniversaries":[{"id":"1775929876410","date":"2026-04-10T00:00:00.000Z","title":"在一起"}],"wishes":[{"id":"1775930430643","date":"2026-04-11T18:00:30.643Z","content":"备考","title":"备考","description":"","tag":"今年内","category":"other","steps":[],"isDone":false},{"id":"1775930410944","date":"2026-04-11T18:00:10.944Z","content":"滨寿司","title":"滨寿司","description":"","tag":"近期推进","category":"food","steps":[],"isDone":false}],"cities":[],"whispers":[{"id":"1775929962535","date":"2026-04-11T17:52:42.535Z","content":"ご主人様、大好き、好き、キス","sender":"user","parentId":null},{"id":"1775929991523","parentId":"1775929962535","date":"2026-04-11T17:53:11.522Z","content":"哦？宝宝什么时候偷偷学了日语？不过光会说可没用，下次见面要拿出点实际行动才算数哦？","sender":"char"},{"id":"1775929991524","date":"2026-04-11T17:53:12.522Z","content":"2026年4月12日，阴。\n\n一整天都没理我，真是个小没良心的。不会是备考太认真，直接忘了自己还有个男朋友吧？搞得我今天打游戏都心不在焉，被周澪那个死人脸念了一晚上，说我像被主人扔掉的猫。啧，他懂个屁。明天再不回我消息，我就要去你们学校广播站贴寻人启事了，说到做到。","sender":"char"},{"id":"1775930008940","date":"2026-04-11T17:53:28.940Z","content":"才没有","sender":"user","parentId":"1775929991524"}],"qa":[],"userId":"uid_1775839756513_ule6jq7k8","characterId":"5ddf97f2-7f53-4c8c-8633-301a1400e275","isUnlocked":true,"animationShown":true,"diaryDecorations":{"user":{"coverColor":"warm","coverPattern":"none","stickers":[],"customImages":[]},"char":{"coverColor":"midnight","co